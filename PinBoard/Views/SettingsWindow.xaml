<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PinBoard.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PinBoard.Views.Controls"
    Title="PinBoard Settings">

    <!-- Root Grid's Background is set in code-behind by ApplyTransparency
         (it can't use a StaticResource on its own resource dictionary —
         the attribute is parsed before Grid.Resources is populated). -->
    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <!-- Brushes whose Colors get mutated at runtime by
                 ApplyTransparency() to switch between translucent (Mica/
                 Acrylic visible) and solid (Mica/Acrylic off) appearances.
                 All child elements that need to swap appearance reference
                 these by StaticResource — mutating the brush's Color
                 propagates to every binding because the references share
                 the same brush instance. -->
            <SolidColorBrush x:Key="LeftColumnBrush"  Color="#28000000"/>
            <SolidColorBrush x:Key="CardBrush"        Color="#305C5C5C"/>
            <SolidColorBrush x:Key="NavSelectedBrush" Color="#305C5C5C"/>

            <!-- ════════════════════════════════════════════════════════════
                 Setting card: dark panel that wraps each row of
                 (icon, title+description, control).
                 ════════════════════════════════════════════════════════════ -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background"    Value="{StaticResource CardBrush}"/>
                <Setter Property="CornerRadius"  Value="6"/>
                <Setter Property="Padding"       Value="20,16"/>
                <Setter Property="Margin"        Value="0,0,0,8"/>
            </Style>

            <Style x:Key="CardIconStyle" TargetType="FontIcon">
                <Setter Property="FontFamily"   Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize"     Value="20"/>
                <Setter Property="Foreground"   Value="#CFCFCF"/>
                <Setter Property="VerticalAlignment"   Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Width"        Value="36"/>
            </Style>

            <Style x:Key="CardTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize"   Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="CardSubtitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#9A9A9A"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize"   Value="28"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,0,0,16"/>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             LEFT COLUMN — titlebar slot at top, nav tiles below.
             Both share the dark #171717 background.
             ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Left-column background. In translucent mode this is a
                 semi-transparent black overlay over the Mica/Acrylic
                 backdrop; in solid mode it becomes opaque #171717. -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Background="{StaticResource LeftColumnBrush}"
                    IsHitTestVisible="False"/>

            <!-- Left half of the drag bar. -->
            <Border x:Name="DragRegionLeft"
                    Grid.Row="0"
                    Background="Transparent"
                    SizeChanged="DragRegion_SizeChanged"
                    Loaded="DragRegion_Loaded"/>

            <!-- App icon + window title, displayed over the drag-bar's left
                 half. IsHitTestVisible="False" lets pointer events fall
                 through to the OS drag region. -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        IsHitTestVisible="False">
                <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                       Width="16" Height="16"
                       Margin="0,0,8,5"
                       VerticalAlignment="Center"/>
                <TextBlock Text="Settings"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>

        <!-- ══════════════════════════════════════════════════════════════
             LEFT COLUMN — nav tiles. Plain Grids with manual selection
             state, because RadioButton's VisualState transitions are
             unreliable in WinUI 3 once a state has been entered once
             (see microsoft-ui-xaml backlog). Each tile is split into:
              • a 14px gutter for the purple selection bar (sits outside
                the tile body, flush with the dark column's left edge);
              • the body (Bg fill + icon + label);
              • a 14px right margin for symmetry.
             ══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1"
                    Margin="0,14,0,0"
                    Spacing="3">
            <Grid x:Name="NavGeneral" Tag="general"
                  Background="Transparent"
                  Height="40"
                  Tapped="NavTile_Tapped"
                  PointerEntered="NavTile_PointerEntered"
                  PointerExited="NavTile_PointerExited">
                <!-- Single-cell layout: all children overlap. Bg is inset by
                     14px on each side, content matches its inset+padding,
                     and the bar is positioned absolutely at x=14 over the
                     top of everything thanks to sibling z-order. -->
                <Border x:Name="NavGeneralBg"
                        Background="{StaticResource NavSelectedBrush}" CornerRadius="4" Opacity="0"
                        Margin="14,0,14,0"/>
                <Grid Margin="24,0,26,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE713;" FontSize="16" FontFamily="Segoe MDL2 Assets"
                              Foreground="White"
                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="General"
                               Foreground="White" FontSize="14"
                               VerticalAlignment="Center"/>
                </Grid>
                <Rectangle x:Name="NavGeneralBar"
                           Width="3" Height="18"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           RadiusX="1.5" RadiusY="1.5"
                           Fill="#8B7BE0" Opacity="0"/>
            </Grid>

            <Grid x:Name="NavHotkey" Tag="hotkey"
                  Background="Transparent"
                  Height="40"
                  Tapped="NavTile_Tapped"
                  PointerEntered="NavTile_PointerEntered"
                  PointerExited="NavTile_PointerExited">
                <Border x:Name="NavHotkeyBg"
                        Background="{StaticResource NavSelectedBrush}" CornerRadius="4" Opacity="0"
                        Margin="14,0,14,0"/>
                <Grid Margin="24,0,26,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE92E;" FontSize="16" FontFamily="Segoe MDL2 Assets"
                              Foreground="White"
                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Hotkey"
                               Foreground="White" FontSize="14"
                               VerticalAlignment="Center"/>
                </Grid>
                <Rectangle x:Name="NavHotkeyBar"
                           Width="3" Height="18"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           RadiusX="1.5" RadiusY="1.5"
                           Fill="#8B7BE0" Opacity="0"/>
            </Grid>

            <Grid x:Name="NavHistory" Tag="history"
                  Background="Transparent"
                  Height="40"
                  Tapped="NavTile_Tapped"
                  PointerEntered="NavTile_PointerEntered"
                  PointerExited="NavTile_PointerExited">
                <Border x:Name="NavHistoryBg"
                        Background="{StaticResource NavSelectedBrush}" CornerRadius="4" Opacity="0"
                        Margin="14,0,14,0"/>
                <Grid Margin="24,0,26,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE81C;" FontSize="16" FontFamily="Segoe MDL2 Assets"
                              Foreground="White"
                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="History"
                               Foreground="White" FontSize="14"
                               VerticalAlignment="Center"/>
                </Grid>
                <Rectangle x:Name="NavHistoryBar"
                           Width="3" Height="18"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           RadiusX="1.5" RadiusY="1.5"
                           Fill="#8B7BE0" Opacity="0"/>
            </Grid>

            <Grid x:Name="NavAbout" Tag="about"
                  Background="Transparent"
                  Height="40"
                  Tapped="NavTile_Tapped"
                  PointerEntered="NavTile_PointerEntered"
                  PointerExited="NavTile_PointerExited">
                <Border x:Name="NavAboutBg"
                        Background="{StaticResource NavSelectedBrush}" CornerRadius="4" Opacity="0"
                        Margin="14,0,14,0"/>
                <Grid Margin="24,0,26,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="16" FontFamily="Segoe MDL2 Assets"
                              Foreground="White"
                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="About"
                               Foreground="White" FontSize="14"
                               VerticalAlignment="Center"/>
                </Grid>
                <Rectangle x:Name="NavAboutBar"
                           Width="3" Height="18"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           RadiusX="1.5" RadiusY="1.5"
                           Fill="#8B7BE0" Opacity="0"/>
            </Grid>
        </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             RIGHT COLUMN — page content fills the entire column. The right
             half of the drag bar plus the window buttons sit as an overlay
             at the top; content scrolls underneath the overlay area, so
             the ScrollViewer's top padding (40) keeps the page title clear
             of the buttons when scrolled to the top.
             ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
        <ScrollViewer x:Name="ContentScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <!-- Inset goes on the Grid's Margin, NOT the ScrollViewer's
                 Padding — ScrollViewer.Padding stays fixed at the viewport
                 edge and the content can't scroll past it. With Margin on
                 the content, the inset scrolls with the rest of the page,
                 so the page title slides under the right-side overlay as
                 you scroll down. -->
            <Grid MaxWidth="780" HorizontalAlignment="Stretch"
                  Margin="32,54,32,32">

                <!-- ── GENERAL ────────────────────────────────────────────── -->
                <StackPanel x:Name="PageGeneral">
                    <TextBlock Text="General" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE7E8;"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="Launch at login"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="Start PinBoard automatically when you sign in to Windows."/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          VerticalAlignment="Center"
                                          MinWidth="0"
                                          OnContent="On" OffContent="Off"
                                          IsOn="{x:Bind ViewModel.RunAtStartup, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE790;"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="Translucent background"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="{x:Bind ViewModel.TransparencyDescription}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          VerticalAlignment="Center"
                                          MinWidth="0"
                                          OnContent="On" OffContent="Off"
                                          IsOn="{x:Bind ViewModel.UseTransparency, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE8B7;"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="Hover to switch group"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="Switch the clipboard popup's group by hovering its tab instead of clicking."/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          VerticalAlignment="Center"
                                          MinWidth="0"
                                          OnContent="On" OffContent="Off"
                                          IsOn="{x:Bind ViewModel.HoverSwitchGroup, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE71D;"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="Default open group"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="Which group the popup starts on each time it opens."/>
                            </StackPanel>
                            <ComboBox Grid.Column="2"
                                      VerticalAlignment="Center"
                                      MinWidth="140"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{x:Bind ViewModel.DefaultOpenGroup, Mode=TwoWay}">
                                <ComboBoxItem Content="Last used" Tag="last"/>
                                <ComboBoxItem Content="All"       Tag="all"/>
                                <ComboBoxItem Content="Text"      Tag="text"/>
                                <ComboBoxItem Content="Image"     Tag="image"/>
                                <ComboBoxItem Content="File"      Tag="files"/>
                                <ComboBoxItem Content="Collect"   Tag="collect"/>
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── HOTKEY ─────────────────────────────────────────────── -->
                <StackPanel x:Name="PageHotkey" Visibility="Collapsed">
                    <TextBlock Text="Hotkey" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE92E;"
                                      VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="Activation shortcut"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="Press this combination from anywhere to open the clipboard popup."
                                           Margin="0,0,0,8"/>
                                <controls:HotkeyPickerControl
                                    Modifiers="{x:Bind ViewModel.HotkeyModifiers, Mode=TwoWay}"
                                    HotkeyKey="{x:Bind ViewModel.HotkeyKey, Mode=TwoWay}"/>
                                <TextBlock Text="{x:Bind ViewModel.HotkeyConflictWarning}"
                                           Style="{StaticResource CardSubtitleStyle}"
                                           Foreground="#E04F5F"
                                           Visibility="{x:Bind ViewModel.ShowHotkeyConflictWarning, Mode=OneWay}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── HISTORY ────────────────────────────────────────────── -->
                <StackPanel x:Name="PageHistory" Visibility="Collapsed">
                    <TextBlock Text="History" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE81C;"
                                      VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource CardTitleStyle}" Text="History capacity"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind ViewModel.HistoryCapDisplay, Mode=OneWay}"
                                               Foreground="#8B7BE0"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}"
                                           Text="Maximum number of unpinned items kept in your clipboard history."/>
                                <Slider Minimum="100" Maximum="10000"
                                        Value="{x:Bind ViewModel.HistoryCap, Mode=TwoWay}"
                                        StepFrequency="100"
                                        SnapsTo="StepValues"
                                        Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE823;"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="Storage time limit"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="Drop unpinned items older than this period. Pinned items are never auto-expired."/>
                            </StackPanel>
                            <ComboBox Grid.Column="2"
                                      VerticalAlignment="Center"
                                      MinWidth="140"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{x:Bind ViewModel.TtlDays, Mode=TwoWay}">
                                <ComboBoxItem Content="Unlimited">
                                    <ComboBoxItem.Tag><x:Int32>0</x:Int32></ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="Day">
                                    <ComboBoxItem.Tag><x:Int32>1</x:Int32></ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="Week">
                                    <ComboBoxItem.Tag><x:Int32>7</x:Int32></ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="Month">
                                    <ComboBoxItem.Tag><x:Int32>30</x:Int32></ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="Quarter">
                                    <ComboBoxItem.Tag><x:Int32>90</x:Int32></ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="Half a year">
                                    <ComboBoxItem.Tag><x:Int32>180</x:Int32></ComboBoxItem.Tag>
                                </ComboBoxItem>
                                <ComboBoxItem Content="Year">
                                    <ComboBoxItem.Tag><x:Int32>365</x:Int32></ComboBoxItem.Tag>
                                </ComboBoxItem>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE74D;"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="Clear history"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="Remove all unpinned items. Pinned items are preserved."/>
                                <TextBlock Text="History cleared."
                                           Style="{StaticResource CardSubtitleStyle}"
                                           Foreground="#5CC8A0"
                                           Visibility="{x:Bind ViewModel.HistoryJustCleared, Mode=OneWay}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="Clear History"
                                    Foreground="#E55A65"
                                    VerticalAlignment="Center"
                                    Click="ClearHistoryButton_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── ABOUT ──────────────────────────────────────────────── -->
                <StackPanel x:Name="PageAbout" Visibility="Collapsed">
                    <TextBlock Text="About" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Style="{StaticResource CardIconStyle}" Glyph="&#xE8C8;"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource CardTitleStyle}"    Text="PinBoard"/>
                                <TextBlock Style="{StaticResource CardSubtitleStyle}" Text="A lightweight clipboard manager for Windows."/>
                                <TextBlock x:Name="VersionText"
                                           Style="{StaticResource CardSubtitleStyle}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Right half of the drag bar — transparent overlay above the
             content, top 32px. Caption rect (set in code-behind) excludes
             the CaptionButtons bounds so their clicks still reach XAML. -->
        <Border x:Name="DragRegionRight"
                VerticalAlignment="Top" Height="40"
                Background="Transparent"
                SizeChanged="DragRegion_SizeChanged"/>

        <StackPanel x:Name="CaptionButtons"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
            <Button Style="{StaticResource CaptionButtonStyle}"
                    Click="MinimizeButton_Click"
                    ToolTipService.ToolTip="Minimize">
                <FontIcon Glyph="&#xE921;" FontSize="10"/>
            </Button>
            <Button x:Name="MaximizeButton"
                    Style="{StaticResource CaptionButtonStyle}"
                    Click="MaximizeButton_Click"
                    ToolTipService.ToolTip="Maximize">
                <FontIcon x:Name="MaximizeGlyph" Glyph="&#xE922;" FontSize="10"/>
            </Button>
            <Button Style="{StaticResource CloseCaptionButtonStyle}"
                    Click="CloseButton_Click"
                    ToolTipService.ToolTip="Close">
                <FontIcon Glyph="&#xE8BB;" FontSize="10"/>
            </Button>
        </StackPanel>
        </Grid>
    </Grid>
</Window>
