<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PinBoard.Views.ClipboardPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PinBoard.ViewModels">

    <Grid x:Name="RootGrid" Background="{ThemeResource LayerFillColorDefaultBrush}" KeyDown="RootGrid_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Filter tabs -->
            <RowDefinition Height="Auto"/>   <!-- Search box -->
            <RowDefinition Height="*"/>      <!-- Items list -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Height="40" Padding="12,0,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="&#xE8C8;" FontSize="16"
                      VerticalAlignment="Center" Margin="0,0,8,0"
                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <TextBlock Grid.Column="1" Text="Clipboard"
                       VerticalAlignment="Center"
                       Style="{StaticResource SubtitleTextBlockStyle}"/>

            <ToggleButton x:Name="PinWindowButton" Grid.Column="2"
                          Width="32" Height="32" Padding="0"
                          VerticalAlignment="Center"
                          Click="PinWindowButton_Click"
                          ToolTipService.ToolTip="Keep window open (hotkey to close)">
                <FontIcon Glyph="&#xE840;" FontSize="14"/>
            </ToggleButton>

            <!-- Drag handle pill. The OS caption region (set in code-behind)
                 pads the hit area beyond the visible bar so it's easy to
                 grab, and the WM_SETCURSOR subclass handler in the popup
                 swaps the cursor to SizeAll (4-way arrow) over any caption
                 region in the window. -->
            <Border x:Name="DragHandle"
                    Grid.ColumnSpan="3"
                    Width="40" Height="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,5,0,0"
                    Background="#66FFFFFF"
                    CornerRadius="2"
                    SizeChanged="DragHandle_SizeChanged"
                    Loaded="DragHandle_Loaded"/>
        </Grid>

        <!-- Filter tab strip. Each tab is a tinted pill (Bg Border at low
             opacity by default, full opacity when selected — same manual-
             selection pattern as the Settings nav tiles, since RadioButton
             VisualState transitions proved unreliable). Click selects;
             hover-to-switch (with 250ms delay) optionally selects when the
             user has the matching setting enabled. -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Stretch"
                    Margin="8,0,8,6" Spacing="4">
            <Grid x:Name="TabAll"     Tag="all"     Width="64" Height="24"
                  Background="Transparent"
                  Tapped="NavTab_Tapped"
                  PointerEntered="NavTab_PointerEntered"
                  PointerExited="NavTab_PointerExited">
                <Border x:Name="TabAllBg"
                        Background="#B19CD9" CornerRadius="10" Opacity="0.35"/>
                <TextBlock Text="All" FontSize="12" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <Grid x:Name="TabText"    Tag="text"    Width="64" Height="24"
                  Background="Transparent"
                  Tapped="NavTab_Tapped"
                  PointerEntered="NavTab_PointerEntered"
                  PointerExited="NavTab_PointerExited">
                <Border x:Name="TabTextBg"
                        Background="#9CCC9C" CornerRadius="10" Opacity="0.35"/>
                <TextBlock Text="Text" FontSize="12" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <Grid x:Name="TabImage"   Tag="image"   Width="64" Height="24"
                  Background="Transparent"
                  Tapped="NavTab_Tapped"
                  PointerEntered="NavTab_PointerEntered"
                  PointerExited="NavTab_PointerExited">
                <Border x:Name="TabImageBg"
                        Background="#FFD78C" CornerRadius="10" Opacity="0.35"/>
                <TextBlock Text="Image" FontSize="12" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <Grid x:Name="TabFile"    Tag="files"   Width="64" Height="24"
                  Background="Transparent"
                  Tapped="NavTab_Tapped"
                  PointerEntered="NavTab_PointerEntered"
                  PointerExited="NavTab_PointerExited">
                <Border x:Name="TabFileBg"
                        Background="#9CB5FF" CornerRadius="10" Opacity="0.35"/>
                <TextBlock Text="File" FontSize="12" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <Grid x:Name="TabCollect" Tag="collect" Width="64" Height="24"
                  Background="Transparent"
                  Tapped="NavTab_Tapped"
                  PointerEntered="NavTab_PointerEntered"
                  PointerExited="NavTab_PointerExited">
                <Border x:Name="TabCollectBg"
                        Background="#D9B19C" CornerRadius="10" Opacity="0.35"/>
                <TextBlock Text="Collect" FontSize="12" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- Search box -->
        <TextBox x:Name="SearchBox"
                 Grid.Row="2"
                 Margin="8,0,8,4"
                 PlaceholderText="Search history..."
                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <TextBox.KeyboardAccelerators>
                <KeyboardAccelerator Key="Escape" Invoked="OnEscapeAccelerator"/>
            </TextBox.KeyboardAccelerators>
        </TextBox>

        <!-- History list -->
        <ListView x:Name="ItemsList"
                  Grid.Row="3"
                  Margin="4,0,4,0"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                  ItemClick="ItemsList_ItemClick">
            <ListView.KeyboardAccelerators>
                <KeyboardAccelerator Key="Escape" Invoked="OnEscapeAccelerator"/>
            </ListView.KeyboardAccelerators>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="Margin" Value="0,0,8,0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ClipItemViewModel">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Preview + source line -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">

                            <!-- Text / Rich items -->
                            <TextBlock Text="{x:Bind PreviewText}"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Visibility="{x:Bind TextVisibility}"/>

                            <!-- Image items -->
                            <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                   MaxHeight="60"
                                   HorizontalAlignment="Left"
                                   Stretch="Uniform"
                                   Visibility="{x:Bind ImageVisibility}"/>

                            <!-- File-drop items -->
                            <StackPanel Visibility="{x:Bind FilesVisibility}">
                                <ItemsControl ItemsSource="{x:Bind FileListPreview, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource BodyTextBlockStyle}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{x:Bind MoreFilesText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="{x:Bind MoreFilesVisibility, Mode=OneWay}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE840;"
                                          FontSize="10"
                                          VerticalAlignment="Center"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                          Visibility="{x:Bind PinnedVisibility, Mode=OneWay}"/>
                                <TextBlock Text="{x:Bind SourceLine}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 3-dot menu — clicking this does NOT trigger ItemClick -->
                        <Button Grid.Column="1"
                                Width="28" Height="28"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="More actions">
                            <FontIcon Glyph="&#xE712;" FontSize="14"/>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight"
                                            Opening="ItemActionsFlyout_Opening">
                                    <MenuFlyoutItem Text="{x:Bind PinMenuLabel, Mode=OneWay}"
                                                    Command="{x:Bind TogglePinCommand}"
                                                    Padding="16,10"
                                                    MinHeight="40"
                                                    MinWidth="180">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="{x:Bind PinMenuGlyph, Mode=OneWay}"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Delete"
                                                    Command="{x:Bind DeleteCommand}"
                                                    Padding="16,10"
                                                    MinHeight="40"
                                                    MinWidth="180">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74D;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer -->
        <Grid Grid.Row="4" Padding="12,4,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.FooterText, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <HyperlinkButton Grid.Column="1"
                             Content="Settings"
                             Padding="0"
                             Click="SettingsButton_Click"/>
        </Grid>
    </Grid>
</Window>
